# Copy to .env and fill in real values before deploying.
# Never commit the real .env file.

# Muapi.ai access key used for all image/video/audio generation.
MUAPI_API_KEY=your_muapi_key_here

# Google AI Studio key used by the Agents / Design Agent features (Gemini Flash Lite).
GOOGLE_AI_STUDIO_KEY=your_google_ai_studio_key_here
